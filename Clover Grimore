local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Clover Grimore",
   LoadingTitle = "Clover Grimore",
   LoadingSubtitle = "by Foil",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false 
})

-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local LP = game:GetService("Players").LocalPlayer
local NpcFolder = workspace:WaitForChild("Npcs")
local QuestFolder = workspace:WaitForChild("Questgivers")

-- Settings
local Settings = {
    AutoFarm = false,
    KillAura = false,
    AutoQuest = false,
    TargetList = {},
    ManualQuest = "None",
    AuraRange = 25,
    AuraHits = 40,
    Distance = 4
}

-- Scrapers
local function GetNpcNames()
    local names = {}
    for _, v in pairs(NpcFolder:GetChildren()) do
        if not table.find(names, v.Name) then table.insert(names, v.Name) end
    end
    table.sort(names)
    return names
end

local function GetQuestNames()
    local quests = {"None"}
    for _, v in pairs(QuestFolder:GetChildren()) do
        table.insert(quests, v.Name)
    end
    table.sort(quests)
    return quests
end

local function GetRealRemote(name)
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v.Name == name and v:IsA("RemoteEvent") then return v end
    end
    return nil
end

local function GetNextTarget()
    local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closestNpc, shortestDist = nil, math.huge
    for _, npcName in pairs(Settings.TargetList) do
        for _, npc in pairs(NpcFolder:GetChildren()) do
            if npc.Name == npcName then
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and npc:FindFirstChild("HumanoidRootPart") then
                    local dist = (npc.HumanoidRootPart.Position - root.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closestNpc = npc
                    end
                end
            end
        end
    end
    return closestNpc
end

--- UI ---
local FarmTab = Window:CreateTab("Farm & Quests", 4483362458)

FarmTab:CreateSection("Targeting")
local MobDropdown = FarmTab:CreateDropdown({
   Name = "Select Mobs to Kill",
   Options = GetNpcNames(),
   CurrentOption = {},
   MultipleOptions = true,
   Callback = function(Options) Settings.TargetList = Options end,
})

FarmTab:CreateButton({
   Name = "Refresh NPC/Quest Lists",
   Callback = function() 
       MobDropdown:Refresh(GetNpcNames())
       -- Note: Rayfield dropdowns usually need a manual re-set for options
   end,
})

FarmTab:CreateSection("Quest Settings")
FarmTab:CreateDropdown({
   Name = "Manual Quest Override",
   Options = GetQuestNames(),
   CurrentOption = "None",
   Callback = function(Option) Settings.ManualQuest = Option[1] end,
})

FarmTab:CreateToggle({
   Name = "AUTO QUEST (Smart/Manual)",
   CurrentValue = false,
   Callback = function(Value) Settings.AutoQuest = Value end,
})

FarmTab:CreateSection("Combat")
FarmTab:CreateToggle({
   Name = "AUTO FARM (TP)",
   CurrentValue = false,
   Callback = function(Value) Settings.AutoFarm = Value end,
})

FarmTab:CreateToggle({
   Name = "KILL AURA",
   CurrentValue = false,
   Callback = function(Value) Settings.KillAura = Value end,
})

FarmTab:CreateSlider({
   Name = "Multi-Hits",
   Range = {1, 100},
   Increment = 1,
   CurrentValue = 40,
   Callback = function(Value) Settings.AuraHits = Value end,
})

--- LOOPS ---

local CurrentTarget = nil

-- TP Loop
RunService.Stepped:Connect(function()
    if Settings.AutoFarm and #Settings.TargetList > 0 then
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if not CurrentTarget or not CurrentTarget.Parent or not CurrentTarget:FindFirstChild("Humanoid") or CurrentTarget.Humanoid.Health <= 0 then
            CurrentTarget = GetNextTarget()
        end
        if CurrentTarget and CurrentTarget:FindFirstChild("HumanoidRootPart") then
            root.Velocity = Vector3.new(0, 0, 0)
            root.CFrame = CurrentTarget.HumanoidRootPart.CFrame * CFrame.new(0, 0, Settings.Distance)
        end
    end
end)

-- Kill Aura
task.spawn(function()
    while task.wait(0.05) do
        if Settings.KillAura then
            local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            local combatRemote = GetRealRemote("Combat")
            if root and combatRemote then
                for _, npc in ipairs(NpcFolder:GetChildren()) do
                    if npc:FindFirstChild("HumanoidRootPart") and (npc.HumanoidRootPart.Position - root.Position).Magnitude <= Settings.AuraRange then
                        local targets = {}
                        for i = 1, Settings.AuraHits do targets[i] = npc end
                        combatRemote:FireServer("Combat", targets, 2, math.random(), root.Position.Y)
                    end
                end
            end
        end
    end
end)

-- Auto Quest Logic
task.spawn(function()
    while task.wait(1) do
        if Settings.AutoQuest then
            local currentQuest = LP:GetAttribute("CurrentQuest")
            
            if not currentQuest or currentQuest == "" then
                local questRemote = GetRealRemote("Quests")
                if questRemote then
                    local questToTake = nil
                    
                    -- Priority 1: Manual Selection
                    if Settings.ManualQuest ~= "None" then
                        questToTake = Settings.ManualQuest
                    -- Priority 2: Smart Auto-Match
                    elseif CurrentTarget then
                        for _, qGiver in pairs(QuestFolder:GetChildren()) do
                            if string.find(string.lower(qGiver.Name), string.lower(CurrentTarget.Name)) then
                                questToTake = qGiver.Name
                                break
                            end
                        end
                    end
                    
                    if questToTake then
                        questRemote:FireServer("giveQuest", questToTake)
                    end
                end
            end
        end
    end
end)
