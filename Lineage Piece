-- Comprehensive Target Validation
local function IsValid(model)
    if not model or not model.Parent then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not model:FindFirstChild("HumanoidRootPart") then return false end
    return true
end

-- Recursive function to find living targets in any boss folder
local function ScanBossFolders(targetName)
    local bossFolder = workspace:FindFirstChild("Boss")
    if not bossFolder then return nil end
    
    -- Checks subfolders like BossSummoner or ServerTimeBossSpawner
    for _, sub in pairs(bossFolder:GetDescendants()) do
        if sub.Name == targetName and IsValid(sub) then
            return sub
        elseif sub:IsA("Model") and sub.Name == targetName then
            -- Check for nested models
            for _, nested in pairs(sub:GetChildren()) do
                if nested.Name == targetName and IsValid(nested) then
                    return nested
                end
            end
        end
    end
    return nil
end

-- Find Best Target (Prioritizing Bosses over Enemies)
local function FindPriorityTarget()
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    
    local potentialTargets = {}

    for _, selectedName in pairs(Settings.TargetList) do
        -- 1. Check Boss Folders First (Priority 2)
        local bossObj = ScanBossFolders(selectedName)
        if bossObj then
            table.insert(potentialTargets, {model = bossObj, priority = 2})
        else
            -- 2. Check Enemies Folder (Priority 1)
            local enemyFolder = workspace:FindFirstChild("Enemies")
            if enemyFolder then
                local item = enemyFolder:FindFirstChild(selectedName)
                if item then
                    local target = IsValid(item) and item or (item:FindFirstChild(selectedName) and IsValid(item[selectedName]) and item[selectedName])
                    if target then
                        table.insert(potentialTargets, {model = target, priority = 1})
                    end
                end
            end
        end
    end

    -- Sort by Priority
    table.sort(potentialTargets, function(a, b) return a.priority > b.priority end)

    return potentialTargets[1] and potentialTargets[1].model or nil
end

local function GetFullList()
    local mobs = {}
    -- Scan Enemies
    local eFolder = workspace:FindFirstChild("Enemies")
    if eFolder then
        for _, v in pairs(eFolder:GetChildren()) do
            if not table.find(mobs, v.Name) then table.insert(mobs, v.Name) end
        end
    end
    -- Scan All Boss Sub-Folders
    local bFolder = workspace:FindFirstChild("Boss")
    if bFolder then
        for _, v in pairs(bFolder:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChildOfClass("Humanoid") then
                if not table.find(mobs, v.Name) then table.insert(mobs, v.Name) end
            end
        end
    end
    table.sort(mobs)
    return mobs
end

