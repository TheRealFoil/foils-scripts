local CurrentTarget = nil

-- Quest Loop
task.spawn(function()
    local QuestEvent = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("_Index")["sleitnick_net@0.2.0"].net["RE/QuestEvent"]
    while task.wait(3) do
        if Settings.AutoFarm and Settings.AutoQuest and #Settings.TargetList > 0 then
            local qId = QuestData[Settings.TargetList[1]]
            if qId then QuestEvent:FireServer("Request", { Id = qId }) end
        end
    end
end)

-- Main Farm Loop
game:GetService("RunService").Heartbeat:Connect(function()
    if Settings.AutoFarm and #Settings.TargetList > 0 then
        local lp = game.Players.LocalPlayer
        if not lp.Character or not lp.Character:FindFirstChild("HumanoidRootPart") then return end

        if not IsValid(CurrentTarget) then
            CurrentTarget = FindPriorityTarget()
        end

        if CurrentTarget and CurrentTarget:FindFirstChild("HumanoidRootPart") then
            local targetRP = CurrentTarget.HumanoidRootPart
            local finalCF
            
            if Settings.Position == "Behind" then
                finalCF = targetRP.CFrame * CFrame.new(0, 0, Settings.Distance)
            elseif Settings.Position == "Above" then
                finalCF = targetRP.CFrame * CFrame.new(0, Settings.Distance, 0) * CFrame.Angles(math.rad(-90), 0, 0)
            elseif Settings.Position == "Under" then
                finalCF = targetRP.CFrame * CFrame.new(0, -Settings.Distance, 0) * CFrame.Angles(math.rad(90), 0, 0)
            end

            lp.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
            lp.Character.HumanoidRootPart.CFrame = finalCF
        end
    end
end)

-- Combat Loop
task.spawn(function()
    local ActionRemote = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("_Index")["sleitnick_net@0.2.0"].net["RE/ActionRemote"]
