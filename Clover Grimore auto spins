local targetRace = "Paladin"
local player = game:GetService("Players").LocalPlayer
local spinRemote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Spins")

_G.AutoSpin = true -- Set to false to stop the script manually

print("Starting auto-spin for: " .. targetRace)

while _G.AutoSpin do
    -- Check the current race attribute from your screenshot
    local currentRace = player:GetAttribute("Race")
    
    if currentRace == targetRace then
        print("Success! You are now an " .. targetRace)
        _G.AutoSpin = false
        break
    end
    
    -- Fire the spin event
    spinRemote:FireServer("Race")
    
    -- Wait a short duration to avoid rate-limiting/kicking
    task.wait(0.5) 
end

